# ─────────────────────────────────────────
# MEMOLOG BACKEND — ENVIRONMENT VARIABLES
# Copy this file, rename it to .env
# Fill in every value before running
# ─────────────────────────────────────────

# MongoDB — get this from mongodb.com (free Atlas cluster)
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/memolog

# JWT Secret — make this a long random string (any keyboard mashing works)
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_like_this_abc123xyz

# JWT expiry — how long login stays valid
JWT_EXPIRES_IN=30d

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cloudinary — for photo storage, get from cloudinary.com (free)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server port
PORT=5000

# Frontend URL (for CORS — change when you deploy)
FRONTEND_URL=http://localhost:3000

# Anthropic API — for AI mood analysis
ANTHROPIC_API_KEY=your_anthropic_api_key
